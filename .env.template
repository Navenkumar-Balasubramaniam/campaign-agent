# OpenRouter — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_TEXT_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b

# Gemini — API key from https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional: use Vertex AI instead of an API key (auth via
# `gcloud auth application-default login`).
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here
GOOGLE_CLOUD_LOCATION=global

MAX_IMAGES_PER_CAMPAIGN=3
APP_NAME=AI Campaign Agent Demo
